name: CI/CD a Docker Hub

on:
  push:
    branches: [ "main" ] # Se ejecuta al hacer push a la rama principal

jobs:
  build-and-push:
    [cite_start]runs-on: ubuntu-latest [cite: 73]

    steps:
    - name: Checkout del código
      [cite_start]uses: actions/checkout@v4 [cite: 74]

    - name: Autenticación en Docker Hub
      [cite_start]uses: docker/login-action@v3 [cite: 75]
      with:
        username: ${{ secrets.DOCKERHUB_USERNAME }}
        [cite_start]password: ${{ secrets.DOCKERHUB_TOKEN }} [cite: 76]

    - name: Configurar Docker Buildx
      [cite_start]uses: docker/setup-buildx-action@v3 [cite: 78]

    - name: Construir y Subir Imagen a Docker Hub
      [cite_start]uses: docker/build-push-action@v5 [cite: 79]
      with:
        context: .
        push: true
        # Reemplaza 'tu-usuario-docker' por tu usuario real de Docker Hub
        tags: jotape2001/vzeta-web:latest
